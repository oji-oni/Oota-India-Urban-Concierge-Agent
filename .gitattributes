# Set default behavior for all files (auto-detect text files and normalize line endings)
* text=auto

# Explicitly declare text files to always be normalized to LF on commit
*.py text eol=lf
*.sh text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
Dockerfile text eol=lf

# Denote binary files (prevent git from trying to modify line endings)
*.zip binary
*.db binary
*.enc binary
*.key binary
