# ─────────────────────────────────────────────────────────────────────────────
# Oota India Urban Concierge — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google / Gemini ───────────────────────────────────────────────────────────
# Your Google AI Studio or Vertex AI API key
GOOGLE_API_KEY=your_google_api_key_here

# Gemini model to use for the agent
# Options: gemini-2.0-flash-exp, gemini-1.5-pro, gemini-2.0-pro-exp
GEMINI_MODEL=gemini-2.0-flash-exp

# ── Storage Paths ─────────────────────────────────────────────────────────────
# Directory where ChromaDB will persist vector embeddings
# Relative paths are resolved from the project root
CHROMA_DATA_DIR=./data/chroma_db

# Path to the SQLite database file (auto-created on first run)
SQLITE_DB_PATH=./data/oota.db

# ── Security ──────────────────────────────────────────────────────────────────
# 32-byte base64-encoded Fernet encryption key for sensitive data at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_base64_fernet_key_here

# ── Agent Defaults ────────────────────────────────────────────────────────────
# Default city slug when user hasn't specified one
# Supported: bengaluru, mumbai, delhi, chennai, hyderabad, kolkata, pune
DEFAULT_CITY=bengaluru

# ── Telegram Bot (Optional) ───────────────────────────────────────────────────
# Token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated list of Telegram user IDs allowed to use the bot
# Leave empty to allow all users (NOT recommended for production)
# Example: 123456789,987654321
TELEGRAM_ALLOWED_USER_IDS=

# ── Ollama (Optional — Local LLM Fallback) ────────────────────────────────────
# URL of your local Ollama server for offline/privacy mode
# Default: http://localhost:11434
OLLAMA_HOST=http://localhost:11434

# ── Webhook / Deployment ──────────────────────────────────────────────────────
# Set to true to run Telegram bot in webhook mode (for production/cloud)
# Set to false (default) to use long-polling (good for local dev)
WEBHOOK_MODE=false

# Public HTTPS URL for the webhook endpoint (required when WEBHOOK_MODE=true)
# Example: https://yourdomain.com/telegram/webhook
WEBHOOK_URL=https://your-domain.com/telegram/webhook

# Port for the FastAPI / uvicorn web server
PORT=8000
